# Hackathon — Cluster 2: "Build" (Scenario 4: Build Your Own Adapter)
#
# No adapters deployed by default. The HyperFleet API, sentinels, and broker
# are running. Participants deploy their own adapters from the skeleton chart
# into per-participant namespaces.
#
# Participants use: helmfile/configs/hackathon/adapters/skeleton/
adapters: []
